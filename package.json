{
  "name": "jsonspecs",
  "version": "2.3.1",
  "description": "Declarative JSON rules engine for validation pipelines",
  "type": "commonjs",
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json",
    "./schema": "./schema/artifact.schema.json",
    "./schema/artifact": "./schema/artifact.schema.json",
    "./schema/snapshot": "./schema/snapshot.schema.json"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "src/**/*.js",
    "schema/*.json",
    "scripts/pack-smoke.js",
    "scripts/perf-smoke.js",
    "README.md",
    "README_RU.md",
    "OPERATORS.md",
    "OPERATORS_RU.md",
    "SPEC.md",
    "SPEC_RU.md",
    "TESTING.md",
    "COMPATIBILITY.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:smoke": "node examples/basic/run.js",
    "test:pack": "node scripts/pack-smoke.js",
    "test:perf": "node scripts/perf-smoke.js",
    "prepublishOnly": "npm test && npm run test:pack && npm run test:perf"
  },
  "keywords": [
    "validation",
    "rules-engine",
    "json",
    "declarative",
    "pipeline",
    "business-rules"
  ],
  "author": "jsonspecs contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catindev/jsonspecs.git"
  },
  "bugs": {
    "url": "https://github.com/catindev/jsonspecs/issues"
  },
  "homepage": "https://github.com/catindev/jsonspecs#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "ajv": "^8.20.0"
  }
}

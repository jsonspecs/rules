{
  "name": "@jsonspecs/rules",
  "version": "4.0.1",
  "description": "Declarative JSON rules engine for validation pipelines",
  "type": "commonjs",
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "src/**/*.js",
    "scripts/pack-smoke.js",
    "scripts/perf-smoke.js",
    "README.md",
    "README_RU.md",
    "OPERATORS.md",
    "OPERATORS_RU.md",
    "IMPLEMENTATION.md",
    "IMPLEMENTATION_RU.md",
    "TESTING.md",
    "COMPATIBILITY.md",
    "MIGRATION_V3.md",
    "MIGRATION_RC6.md",
    "MIGRATION_RC6_RU.md",
    "MIGRATION_RC7.md",
    "MIGRATION_RC7_RU.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:conformance": "node scripts/verify-conformance-source.js && node scripts/conformance.js",
    "test:smoke": "node examples/basic/run.js",
    "test:pack": "node scripts/pack-smoke.js",
    "test:perf": "node scripts/perf-smoke.js",
    "prepublishOnly": "npm test && npm run test:conformance && npm run test:pack && npm run test:perf"
  },
  "keywords": [
    "validation",
    "rules-engine",
    "json",
    "declarative",
    "pipeline",
    "business-rules"
  ],
  "author": "jsonspecs contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsonspecs/rules.git"
  },
  "bugs": {
    "url": "https://github.com/jsonspecs/rules/issues"
  },
  "homepage": "https://github.com/jsonspecs/rules#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "re2-wasm": "1.0.2"
  }
}

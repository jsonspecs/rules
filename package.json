{
  "name": "jsonspecs",
  "version": "2.0.0",
  "description": "Composable validation pipelines powered by JSON rules",
  "type": "commonjs",
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src/**/*.js",
    "README.md",
    "OPERATORS.md",
    "SPEC.md",
    "COMPATIBILITY.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:smoke": "node examples/basic/run.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "validation",
    "rules-engine",
    "json",
    "declarative",
    "pipeline",
    "business-rules"
  ],
  "author": "jsonspecs contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/catindev/jsonspecs"
  },
  "bugs": {
    "url": "https://github.com/catindev/jsonspecs/issues"
  },
  "homepage": "https://github.com/catindev/jsonspecs#readme",
  "engines": {
    "node": ">=20"
  }
}

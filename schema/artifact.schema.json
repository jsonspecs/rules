{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jsonspecs.dev/schema/artifact.schema.json",
  "title": "jsonspecs artifact",
  "oneOf": [
    { "$ref": "#/$defs/rule" },
    { "$ref": "#/$defs/pipeline" },
    { "$ref": "#/$defs/condition" },
    { "$ref": "#/$defs/dictionary" }
  ],
  "$defs": {
    "base": {
      "type": "object",
      "required": ["id", "type", "description"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["rule", "pipeline", "condition", "dictionary"] },
        "description": { "type": "string" }
      }
    },
    "step": {
      "type": "object",
      "oneOf": [
        { "required": ["rule"] },
        { "required": ["pipeline"] },
        { "required": ["condition"] }
      ],
      "properties": {
        "rule": { "type": "string", "minLength": 1 },
        "pipeline": { "type": "string", "minLength": 1 },
        "condition": { "type": "string", "minLength": 1 },
        "stepId": { "type": "string", "minLength": 1 }
      }
    },
    "when": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["all"],
          "properties": {
            "all": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/when" } }
          }
        },
        {
          "type": "object",
          "required": ["any"],
          "properties": {
            "any": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/when" } }
          }
        }
      ]
    },
    "aggregate": {
      "type": "object",
      "properties": {
        "mode": { "enum": ["EACH", "ANY", "ALL", "COUNT", "MIN", "MAX"] },
        "onEmpty": { "enum": ["PASS", "FAIL", "ERROR", "TRUE", "FALSE", "UNDEFINED"] },
        "op": { "enum": ["=", "==", "!=", ">", ">=", "<", "<="] },
        "value": { "type": "number" },
        "summaryIssue": { "type": "boolean" }
      }
    },
    "rule": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "role", "operator"],
          "properties": {
            "type": { "const": "rule" },
            "role": { "enum": ["check", "predicate"] },
            "operator": { "type": "string", "minLength": 1 },
            "field": { "type": "string", "minLength": 1 },
            "fields": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
            "value_field": { "type": "string", "minLength": 1 },
            "level": { "enum": ["WARNING", "ERROR", "EXCEPTION"] },
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 },
            "flags": { "type": "string" },
            "dictionary": {
              "type": "object",
              "required": ["type", "id"],
              "properties": { "type": { "const": "static" }, "id": { "type": "string", "minLength": 1 } }
            },
            "aggregate": { "$ref": "#/$defs/aggregate" },
            "meta": { "type": "object" }
          },
          "allOf": [
            {
              "if": { "properties": { "role": { "const": "check" } }, "required": ["role"] },
              "then": { "required": ["level", "code", "message"] },
              "else": { "not": { "anyOf": [{ "required": ["level"] }, { "required": ["code"] }, { "required": ["message"] }] } }
            },
            {
              "if": { "properties": { "role": { "const": "check" } }, "required": ["role"] },
              "then": {
                "properties": {
                  "aggregate": {
                    "type": "object",
                    "properties": {
                      "mode": { "enum": ["EACH", "ALL", "COUNT", "MIN", "MAX"] },
                      "onEmpty": { "enum": ["PASS", "FAIL", "ERROR"] }
                    }
                  }
                }
              },
              "else": {
                "properties": {
                  "aggregate": {
                    "type": "object",
                    "properties": {
                      "mode": { "enum": ["ANY", "ALL", "COUNT"] },
                      "onEmpty": { "enum": ["TRUE", "FALSE", "UNDEFINED", "ERROR"] }
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    },
    "pipeline": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "flow", "strict", "entrypoint"],
          "properties": {
            "type": { "const": "pipeline" },
            "flow": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/step" } },
            "strict": { "type": "boolean" },
            "entrypoint": { "type": "boolean" },
            "required_context": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "strictCode": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 }
          },
          "if": { "properties": { "strict": { "const": true } }, "required": ["strict"] },
          "then": { "required": ["message"] }
        }
      ]
    },
    "condition": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "when", "steps"],
          "properties": {
            "type": { "const": "condition" },
            "when": { "$ref": "#/$defs/when" },
            "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/step" } }
          }
        }
      ]
    },
    "dictionary": {
      "allOf": [
        { "$ref": "#/$defs/base" },
        {
          "type": "object",
          "required": ["id", "type", "entries"],
          "properties": {
            "type": { "const": "dictionary" },
            "entries": { "type": "array" }
          }
        }
      ]
    }
  }
}

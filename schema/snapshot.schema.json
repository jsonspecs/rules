{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jsonspecs.dev/schema/snapshot.schema.json",
  "title": "jsonspecs snapshot",
  "type": "object",
  "required": ["format", "formatVersion", "sourceHash", "engine", "artifacts"],
  "properties": {
    "format": { "const": "jsonspecs-snapshot" },
    "formatVersion": { "const": 1 },
    "sourceHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "engine": {
      "type": "object",
      "required": ["minVersion"],
      "properties": { "minVersion": { "type": "string", "minLength": 1 } }
    },
    "artifacts": { "type": "array", "items": { "$ref": "artifact.schema.json" } },
    "meta": {
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "minLength": 1 },
        "projectTitle": { "type": "string" },
        "description": { "type": "string" },
        "rulesetVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$" }
      },
      "additionalProperties": true
    }
  }
}
